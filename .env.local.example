# Hugging Face
HF_API_TOKEN=your_hugging_face_token_here
# Enable "Inference Providers" on your HF token: https://huggingface.co/settings/tokens
#
# Scan detection (recommended for hackathon — do not change unless you test a replacement):
#   - HF_DEEPFAKE_MODEL_URL: dima806/... (free router inference; good on classic deepfakes, weak on morphs)
#   - Browser: face-api + morph/blend heuristics + canvas artifacts (handles face-swap / morph)
# Do NOT switch to SigLIP models here unless you add a separate Python inference service;
# they often lack HF Serverless image inference for raw POST.
HF_DEEPFAKE_MODEL_URL=dima806/deepfake_vs_real_image_detection
HF_LLM_MODEL_URL=meta-llama/Llama-3.1-8B-Instruct

# Timeouts (ms)
HF_TIMEOUT_MS=30000

# Hackathon-safe throttling (best-effort; in-memory per server instance)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# LLM knobs
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.4

# App URL (used for links/callbacks if needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — set on the FRONTEND Vercel project (deepshield-frontend), not the API:
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# Redirect URI in Google Console: https://YOUR-FRONTEND/api/auth/google/callback

# Required for automatic in-app reverse-image matches (pick one or both):
# SERPAPI_API_KEY=your_serpapi_key_here   # https://serpapi.com (Google Lens)
# SERPER_API_KEY=your_serper_key_here     # https://serper.dev (Google Lens, often cheaper)

# Sightengine face-swap / deepfake detection (scan) — https://sightengine.com
# SIGHTENGINE_API_USER=your_api_user
# SIGHTENGINE_API_SECRET=your_api_secret

