# Hugging Face
HF_API_TOKEN=your_hugging_face_token_here
# Model id or legacy .../models/<id> URL (api-inference URLs are auto-converted to router)
HF_DEEPFAKE_MODEL_URL=dima806/deepfake_vs_real_image_detection
HF_LLM_MODEL_URL=meta-llama/Llama-3.1-8B-Instruct

# Timeouts (ms)
HF_TIMEOUT_MS=30000

# Hackathon-safe throttling (best-effort; in-memory per server instance)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# LLM knobs
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.4

# App URL (used for links/callbacks if needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000

