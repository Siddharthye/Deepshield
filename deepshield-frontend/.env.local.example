# Vercel requires a non-empty value — use "same-origin" (recommended with vercel.json rewrites).
# Or set full backend URL only if you added CORS on the API.
NEXT_PUBLIC_API_URL=same-origin

# Google OAuth (sign-in) — set on FRONTEND Vercel project only (not the API backend).
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs (add every URL you use — must match exactly):
#   http://localhost:3000/api/auth/google/callback
#   https://YOUR-FRONTEND.vercel.app/api/auth/google/callback
# After deploy, open https://YOUR-FRONTEND/api/auth/google/setup — copy registerInGoogleConsole into Google Cloud Console.
# Set this to your MAIN production callback (must match Google Console exactly):
# GOOGLE_REDIRECT_URI=https://YOUR-FRONTEND.vercel.app/api/auth/google/callback
# Or set your stable public site URL (redirect URI is derived automatically):
# NEXT_PUBLIC_APP_URL=https://YOUR-FRONTEND.vercel.app
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret