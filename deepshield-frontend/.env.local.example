# Vercel requires a non-empty value — use "same-origin" (recommended with vercel.json rewrites).
# Or set full backend URL only if you added CORS on the API.
NEXT_PUBLIC_API_URL=same-origin

# Google OAuth (sign-in) — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web). Authorized redirect URI:
#   http://localhost:3000/api/auth/google/callback
#   https://YOUR-FRONTEND-DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret